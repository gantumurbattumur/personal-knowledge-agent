{
    "name": "rag-assistant",
    "displayName": "RAG Assistant",
    "description": "Query your personal knowledge base from VSCode",
    "version": "0.1.0",
    "publisher": "pka",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "rag.askWorkspace",
                "title": "RAG: Ask about this workspace"
            },
            {
                "command": "rag.health",
                "title": "RAG: Check daemon status"
            }
        ],
        "keybindings": [
            {
                "command": "rag.askWorkspace",
                "key": "ctrl+shift+r",
                "mac": "cmd+shift+r"
            }
        ],
        "configuration": {
            "title": "RAG Assistant",
            "properties": {
                "rag.daemonUrl": {
                    "type": "string",
                    "default": "http://localhost:8741",
                    "description": "URL of the PKA daemon"
                },
                "rag.token": {
                    "type": "string",
                    "default": "",
                    "description": "Auth token for the daemon (from ~/.pka/daemon_token)"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@types/vscode": "^1.85.0",
        "typescript": "^5.3.0",
        "eslint": "^8.56.0",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0"
    }
}